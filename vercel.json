  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/api" }
  ],
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/thiagosilvapersonal/**"
    }
  }
}
